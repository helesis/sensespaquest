# Kopyala: copy .env.example .env   sonra degerleri doldur.

# HTTP sunucu portu (varsayilan 3000)
PORT=3000

# SQL Server / Lapis baglantisi (server.js)
LAPIS_SERVER=your-sql-host
LAPIS_DATABASE=your-database-name
LAPIS_USERNAME=your-login
LAPIS_PASSWORD=your-password
LAPIS_PORT=1433

# true: Azure / uzak sunucu SSL; false: cogu yerel / guvenilir ag
LAPIS_ENCRYPT=false

# true: self-signed sertifikada baglanti (gelistirme icin sik kullanilir)
LAPIS_TRUST_SERVER_CERTIFICATE=true
